#!/usr/bin/env bash
set -euo pipefail

INSTALL_ROOT="${1:?install root required}"
VERSION="${2:?version required}"
APP_SRC="$INSTALL_ROOT/app-src"
BUILD_NUMBER="$(node -e 'const p=require(process.argv[1]); process.stdout.write(String(p["codexBuildNumber"] || ""))' "$APP_SRC/package.json")"

mkdir -p "$INSTALL_ROOT/bin" "$INSTALL_ROOT/share/icons/hicolor/scalable/apps"

cat > "$INSTALL_ROOT/bin/codex-cli-wrapper" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

candidates=()
for root in "$HOME/.local/lib/node_modules/@openai/codex" "$HOME/.local/share/pnpm/global" "/usr/lib/node_modules/@openai/codex"; do
  if [[ -d "$root" && -f "$root/bin/codex.js" ]]; then
    candidates+=("$root")
  elif [[ -d "$root" ]]; then
    while IFS= read -r found; do
      candidates+=("$found")
    done < <(find "$root" -type f -path '*/node_modules/@openai/codex/bin/codex.js' -printf '%h/..\n' 2>/dev/null)
  fi
done

if [[ "${#candidates[@]}" -eq 0 ]]; then
  echo "codex-cli-wrapper: @openai/codex is not installed" >&2
  exit 127
fi

selected="$(printf '%s\n' "${candidates[@]}" | sort -V | tail -n 1)"
exec /usr/bin/node "$selected/bin/codex.js" "$@"
EOF

cat > "$INSTALL_ROOT/bin/codex-ui-linux" <<EOF
#!/usr/bin/env bash
set -euo pipefail

APP_ROOT="/opt/codex-ui-linux-port"
ELECTRON_BIN="\${ELECTRON_BIN:-electron42}"
CLI_WRAPPER="\$APP_ROOT/bin/codex-cli-wrapper"

if [[ "\${1:-}" == "--version" ]]; then
  echo "codex-ui-linux $VERSION"
  exit 0
fi

export BUILD_FLAVOR=prod
export CODEX_BUILD_NUMBER="\${CODEX_BUILD_NUMBER:-$BUILD_NUMBER}"
export CODEX_CLI_PATH="\$CLI_WRAPPER"

locale_value="\${CODEXUI_LANG:-\${LC_ALL:-\${LC_MESSAGES:-\${LANG:-}}}}"
locale_value="\${locale_value%%.*}"
locale_value="\${locale_value%%@*}"
locale_value="\${locale_value//_/-}"

electron_args=()
if [[ -n "\$locale_value" && "\$locale_value" != "C" && "\$locale_value" != "POSIX" ]]; then
  electron_args+=(--lang="\$locale_value")
fi
if [[ -n "\${CODEXUI_OZONE_PLATFORM:-}" ]]; then
  electron_args+=(--ozone-platform="\$CODEXUI_OZONE_PLATFORM")
fi
if [[ -n "\${CODEXUI_ELECTRON_FLAGS:-}" ]]; then
  read -r -a configured_flags <<< "\$CODEXUI_ELECTRON_FLAGS"
  electron_args+=("\${configured_flags[@]}")
fi

exec "\$ELECTRON_BIN" "\${electron_args[@]}" "\$APP_ROOT/app-src" "\$@"
EOF

chmod 755 "$INSTALL_ROOT/bin/codex-cli-wrapper" "$INSTALL_ROOT/bin/codex-ui-linux"

if [[ -f "$APP_SRC/.vite/build/bootstrap.js" ]]; then
  node - "$APP_SRC/.vite/build/bootstrap.js" <<'NODE'
const fs = require("fs");
const file = process.argv[2];
let text = fs.readFileSync(file, "utf8");
const before = "let i=require(`electron`),a=require(`node:path`);";
const bridgeMarker = "codexui-linux-control-bridge";
const bridgeV2 = String.raw`try{
globalThis.__codexUiLinuxControlBridge="codexui-linux-control-bridge";
(()=>{
const fs=require("node:fs"),net=require("node:net"),path=require("node:path"),os=require("node:os");
function visibleWindow(){
  const focused=i.BrowserWindow.getFocusedWindow();
  if(focused&&!focused.isDestroyed()&&focused.isVisible())return focused;
  return i.BrowserWindow.getAllWindows().find(w=>!w.isDestroyed()&&w.isVisible());
}
function showWindow(win){
  if(!win)throw Error("no visible Codex window");
  if(win.isMinimized())win.restore();
  win.show();
  win.focus();
}
async function startDictation(win){
  showWindow(win);
  await win.webContents.executeJavaScript("(()=>{const opts={key:\"D\",code:\"KeyD\",ctrlKey:true,shiftKey:true,bubbles:true,cancelable:true,composed:true};const targets=[window,document,document.activeElement].filter(Boolean);for(const target of targets){try{target.dispatchEvent(new KeyboardEvent(\"keydown\",opts))}catch{}}setTimeout(()=>{for(const target of targets){try{target.dispatchEvent(new KeyboardEvent(\"keyup\",opts))}catch{}}},80);})()",true);
  return {ok:true};
}
function promptScript(prompt,submit){
  return "(async()=>{const text="+JSON.stringify(String(prompt||""))+";const submit="+(submit===false?"false":"true")+";function visible(el){if(!el||!el.getBoundingClientRect)return false;const r=el.getBoundingClientRect();const s=getComputedStyle(el);return r.width>0&&r.height>0&&s.visibility!==\"hidden\"&&s.display!==\"none\";}function box(el){if(!visible(el))return false;const tag=(el.tagName||\"\").toLowerCase();return tag===\"textarea\"||tag===\"input\"||el.isContentEditable||el.getAttribute(\"contenteditable\")===\"true\"||el.getAttribute(\"role\")===\"textbox\";}function pick(){const active=document.activeElement;if(box(active))return active;const all=Array.from(document.querySelectorAll(\"textarea,input[type=text],[contenteditable=true],[role=textbox]\")).filter(box);return all[all.length-1]||null;}function setText(el,value){el.focus();const tag=(el.tagName||\"\").toLowerCase();if(tag===\"textarea\"||tag===\"input\"){const proto=tag===\"textarea\"?HTMLTextAreaElement.prototype:HTMLInputElement.prototype;const setter=Object.getOwnPropertyDescriptor(proto,\"value\")?.set;if(setter)setter.call(el,value);else el.value=value;el.dispatchEvent(new InputEvent(\"input\",{bubbles:true,inputType:\"insertText\",data:value}));el.dispatchEvent(new Event(\"change\",{bubbles:true}));return;}try{document.execCommand(\"selectAll\",false,null);document.execCommand(\"insertText\",false,value);}catch{el.textContent=value;}el.dispatchEvent(new InputEvent(\"input\",{bubbles:true,inputType:\"insertText\",data:value}));}function buttonLabel(b){return String((b.getAttribute(\"aria-label\")||\"\")+\" \"+(b.title||\"\")+\" \"+(b.textContent||\"\")).toLowerCase();}const el=pick();if(!el)throw Error(\"no prompt field found\");setText(el,text);await new Promise(r=>setTimeout(r,180));if(submit){const buttons=Array.from(document.querySelectorAll(\"button\")).filter(visible).reverse();const send=buttons.find(b=>!b.disabled&&/(send|enviar|submit)/.test(buttonLabel(b)));if(send){send.click();return {inserted:true,submitted:\"button\"};}const opts={key:\"Enter\",code:\"Enter\",bubbles:true,cancelable:true,composed:true};el.dispatchEvent(new KeyboardEvent(\"keydown\",opts));el.dispatchEvent(new KeyboardEvent(\"keyup\",opts));return {inserted:true,submitted:\"enter\"};}return {inserted:true,submitted:false};})()";
}
async function submitPrompt(win,payload){
  showWindow(win);
  const prompt=String(payload.prompt||"").trim();
  if(!prompt)throw Error("empty prompt");
  const result=await win.webContents.executeJavaScript(promptScript(prompt,payload.submit),true);
  return {ok:true,result};
}
function readScript(mode){
  return "(async()=>{const mode="+JSON.stringify(String(mode||"selection"))+";function visible(el){if(!el||!el.getBoundingClientRect)return false;const r=el.getBoundingClientRect();const s=getComputedStyle(el);return r.width>0&&r.height>0&&s.visibility!==\"hidden\"&&s.display!==\"none\";}function clean(s){return String(s||\"\").replace(/\\s+/g,\" \").trim();}if(mode===\"selection\"){const selected=clean(window.getSelection&&window.getSelection().toString());if(selected)return {text:selected,source:\"selection\"};}const nodes=Array.from(document.querySelectorAll(\"main article,[data-message-author-role],.markdown,main,[role=main]\")).filter(visible);const texts=nodes.map(n=>clean(n.innerText||n.textContent)).filter(Boolean);if(mode===\"last-response\"){for(let i=texts.length-1;i>=0;i--){const text=texts[i];if(text.length>40)return {text,source:\"last-response\"};}if(texts.length)return {text:texts[texts.length-1],source:\"last-visible\"};}const body=clean((document.body&&document.body.innerText)||\"\");return {text:body,source:\"visible\"};})()";
}
async function readText(win,payload){
  showWindow(win);
  const result=await win.webContents.executeJavaScript(readScript(payload.mode),true);
  const text=String(result&&result.text||"").trim();
  if(!text)throw Error("no readable text found");
  return {ok:true,text,source:String(result&&result.source||"unknown")};
}
function handle(payload){
  const win=visibleWindow();
  if(payload.command==="start-dictation")return startDictation(win);
  if(payload.command==="submit-prompt")return submitPrompt(win,payload);
  if(payload.command==="read-text")return readText(win,payload);
  throw Error("unsupported command");
}
function setup(){
  const runtime=process.env.XDG_RUNTIME_DIR||path.join(os.tmpdir(),"codex-ui-"+(process.getuid?.()??"user"));
  const dir=path.join(runtime,"codex-ui-linux-port");
  fs.mkdirSync(dir,{recursive:true,mode:0o700});
  const sock=path.join(dir,"control.sock");
  try{if(fs.existsSync(sock))fs.unlinkSync(sock)}catch{}
  const server=net.createServer(conn=>{
    let buffer="";
    conn.setEncoding("utf8");
    conn.on("data",chunk=>{
      buffer+=chunk;
      if(!buffer.includes("\n"))return;
      const line=buffer.trim();
      buffer="";
      Promise.resolve().then(()=>{let payload;try{payload=JSON.parse(line)}catch{payload={command:line}}return handle(payload)}).then(result=>{conn.write(JSON.stringify(result)+"\n");conn.end()}).catch(err=>{conn.write(JSON.stringify({ok:false,error:String(err?.message||err)})+"\n");conn.end()});
    });
  });
  server.listen(sock,()=>{try{fs.chmodSync(sock,0o600)}catch{}});
}
i.app.whenReady().then(setup).catch(()=>{});
})();
}catch{}`;
const menuPatch = "try{i.Menu.setApplicationMenu(null),i.app.on(`browser-window-created`,(e,t)=>{try{t.setMenuBarVisibility(!1),t.removeMenu?.()}catch{}})}catch{}";
const electronRequire = "let i=require(`electron`);";
const menuPatchStart = "try{i.Menu.setApplicationMenu";
if (text.includes(bridgeMarker) && text.includes(menuPatchStart) && (!text.includes("submit-prompt") || !text.includes("read-text"))) {
  const start = text.indexOf(electronRequire);
  const bridgeStart = start === -1 ? -1 : start + electronRequire.length;
  const bridgeEnd = text.indexOf(menuPatchStart, bridgeStart);
  if (bridgeStart !== -1 && bridgeEnd > bridgeStart) {
    text = text.slice(0, bridgeStart) + bridgeV2 + text.slice(bridgeEnd);
    fs.writeFileSync(file, text, "utf8");
  }
}
if (text.includes(before)) {
  const after = `let i=require(\`electron\`);${bridgeV2}${menuPatch}let a=require(\`node:path\`);`;
  if (!text.includes(bridgeMarker) || !text.includes("Menu.setApplicationMenu(null)")) {
    text = text.replace(before, after);
    fs.writeFileSync(file, text, "utf8");
  }
} else {
  if (!text.includes(bridgeMarker)) {
    text = text.replace("let i=require(`electron`);", `let i=require(\`electron\`);${bridgeV2}`);
  }
  if (!text.includes("Menu.setApplicationMenu(null)")) {
    text = text.replace("let i=require(`electron`);", `let i=require(\`electron\`);${menuPatch}`);
  }
  fs.writeFileSync(file, text, "utf8");
}
NODE
fi

workspace_root_drop_handlers=("$APP_SRC"/.vite/build/workspace-root-drop-handler-*.js)
if [[ -f "${workspace_root_drop_handlers[0]:-}" ]]; then
  node - "${workspace_root_drop_handlers[@]}" <<'NODE'
const fs = require("fs");
const before = "function Qe(){let e=process._linkedBinding;if(typeof e!=`function`)throw Error(`Owl feature binding is unavailable`);return Ge.parse(e.call(process,`electron_common_owl_features`))}";
const after = "function Qe(){let e=process._linkedBinding;if(typeof e==`function`)try{return Ge.parse(e.call(process,`electron_common_owl_features`))}catch{}return Ge.parse({isOwlFeatureEnabled:e=>nt(rt(`enable-features`)).includes(e)&&!nt(rt(`disable-features`)).includes(e)})}";
for (const file of process.argv.slice(2)) {
  let text = fs.readFileSync(file, "utf8");
  if (text.includes("electron_common_owl_features`))}catch{}")) {
    continue;
  }
  if (text.includes(before)) {
    text = text.replace(before, after);
    fs.writeFileSync(file, text, "utf8");
    continue;
  }
  if (text.includes("Owl feature binding is unavailable")) {
    throw new Error(`unrecognized Owl feature binding shape in ${file}`);
  }
}
NODE
fi

shell_css="$(find "$APP_SRC/webview/assets" -maxdepth 1 -name 'app-shell-*.css' | head -n 1)"
if [[ -n "$shell_css" ]] && ! grep -q "Local Linux port visual override" "$shell_css"; then
  cat >> "$shell_css" <<'CSS'

/* Local Linux port visual override. */
:root[data-codex-window-type=electron]{
  --vscode-font-family:"Inter","OpenAI Sans","Segoe UI",system-ui,sans-serif;
  --vscode-font-weight:400;
  --vscode-font-size:13px;
  --vscode-editor-font-size:12px;
  --height-toolbar:40px;
  --height-toolbar-sm:34px;
  --spacing-token-sidebar:280px;
  --codex-titlebar-tint:var(--color-token-main-surface-primary);
}
:root[data-codex-window-type=electron] body{background:var(--color-token-main-surface-primary);-webkit-font-smoothing:antialiased;text-rendering:geometricPrecision}
:root[data-codex-window-type=electron] .app-header-tint{background:var(--color-token-main-surface-primary)!important;border-bottom:1px solid var(--color-token-border-default,transparent)}
:root[data-codex-window-type=electron] .app-shell-left-panel{background:var(--color-token-main-surface-primary)!important;overflow:hidden!important;border-right:1px solid var(--color-token-border-default,transparent)}
:root[data-codex-window-type=electron] .app-shell-left-panel:after{display:none!important}
:root[data-codex-window-type=electron] .app-shell-left-panel button,
:root[data-codex-window-type=electron] .app-shell-left-panel [role=button],
:root[data-codex-window-type=electron] .app-shell-left-panel a{font-size:13px!important;line-height:1.35!important}
:root[data-codex-window-type=electron] .main-surface{border-top-left-radius:10px!important;border-bottom-left-radius:10px!important}
CSS
fi

cat > "$INSTALL_ROOT/share/codex-ui-linux.desktop" <<'EOF'
[Desktop Entry]
Type=Application
Name=Codex UI
Comment=Codex UI Linux Port
Exec=codex-ui-linux %U
Icon=codex-ui-linux
Terminal=false
Categories=Development;
StartupNotify=true
EOF

cat > "$INSTALL_ROOT/share/icons/hicolor/scalable/apps/codex-ui-linux.svg" <<'EOF'
<svg xmlns="http://www.w3.org/2000/svg" width="512" height="512" viewBox="0 0 512 512">
  <rect width="512" height="512" rx="96" fill="#111827"/>
  <path d="M256 72 414 164v184L256 440 98 348V164L256 72Z" fill="none" stroke="#67e8f9" stroke-width="34" stroke-linejoin="round"/>
  <path d="M256 144 352 200v112l-96 56-96-56V200l96-56Z" fill="none" stroke="#a7f3d0" stroke-width="28" stroke-linejoin="round"/>
  <circle cx="256" cy="256" r="38" fill="#67e8f9"/>
</svg>
EOF
