#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SOURCE=""
VERSION=""
WORKDIR="$ROOT/build/work"
DIST="$ROOT/dist"

usage() {
  cat <<'EOF'
Usage:
  scripts/build-from-dmg --source /path/to/Codex.dmg|Codex.zip [--version VERSION]
  scripts/build-from-dmg --dmg /path/to/Codex.dmg [--version VERSION]
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --source) shift; SOURCE="${1:-}" ;;
    --dmg) shift; SOURCE="${1:-}" ;;
    --version) shift; VERSION="${1:-}" ;;
    --help|-h) usage; exit 0 ;;
    *) echo "build-from-dmg: unknown option: $1" >&2; usage >&2; exit 2 ;;
  esac
  shift
done

[[ -f "$SOURCE" ]] || { echo "build-from-dmg: source archive not found: $SOURCE" >&2; exit 2; }

need() {
  command -v "$1" >/dev/null 2>&1 || { echo "build-from-dmg: missing command: $1" >&2; exit 2; }
}

need 7z
need node
need npm
need patch
need tar
need sha256sum

rm -rf "$WORKDIR"
mkdir -p "$WORKDIR" "$DIST"

source_sha="$(sha256sum "$SOURCE" | awk '{print $1}')"
source_ext="${SOURCE%%\?*}"
source_ext="${source_ext##*.}"
case "$source_ext" in dmg|zip) ;; *) echo "build-from-dmg: unsupported source archive extension: $source_ext" >&2; exit 2 ;; esac
extract="$WORKDIR/dmg"
mkdir -p "$extract"
7z x -y -o"$extract" "$SOURCE" >/dev/null

asar_path="$(find "$extract" -path '*/Codex.app/Contents/Resources/app.asar' -type f | head -n 1)"
unpacked_path="$(find "$extract" -path '*/Codex.app/Contents/Resources/app.asar.unpacked' -type d | head -n 1)"
icon_path="$(find "$extract" -path '*/Codex.app/Contents/Resources/icon.icns' -type f | head -n 1)"

[[ -f "$asar_path" ]] || { echo "build-from-dmg: app.asar not found" >&2; exit 1; }

app_src="$WORKDIR/app-src"
npx --yes @electron/asar extract "$asar_path" "$app_src"

if [[ -z "$VERSION" ]]; then
  VERSION="$(node -e 'const p=require(process.argv[1]); process.stdout.write(p.version)' "$app_src/package.json")"
fi

install_root="$WORKDIR/pkgroot/opt/codex-ui-linux-port"
mkdir -p "$install_root"
cp -a "$app_src" "$install_root/app-src"
if [[ -n "$unpacked_path" ]]; then
  mkdir -p "$install_root/app-src/app.asar.unpacked"
  cp -a "$unpacked_path"/. "$install_root/app-src/app.asar.unpacked/"
fi

native_build="$WORKDIR/native-build"
mkdir -p "$native_build"
pushd "$native_build" >/dev/null
npm init -y >/dev/null
npm install --omit=dev better-sqlite3@12.9.0 node-pty@1.1.0
"$ROOT/scripts/patch-native-modules" "$native_build"
npx --yes @electron/rebuild -v 42.1.0 -m node_modules/better-sqlite3
npx --yes @electron/rebuild -v 42.1.0 -m node_modules/node-pty
popd >/dev/null
mkdir -p "$install_root/app-src/node_modules"
rm -rf "$install_root/app-src/node_modules/better-sqlite3" "$install_root/app-src/node_modules/node-pty"
cp -a "$native_build/node_modules/better-sqlite3" "$install_root/app-src/node_modules/"
cp -a "$native_build/node_modules/node-pty" "$install_root/app-src/node_modules/"

"$ROOT/scripts/apply-linux-patches" "$install_root" "$VERSION"
"$ROOT/scripts/build-packages" "$WORKDIR/pkgroot" "$VERSION" "$source_sha"

source_archive_file="Codex-${VERSION}.${source_ext}"
cp "$SOURCE" "$DIST/$source_archive_file"

cat > "$DIST/manifest.json" <<JSON
{
  "version": "$VERSION",
  "sourceArchiveFile": "$source_archive_file",
  "sourceArchiveSha256": "$source_sha",
  "generatedAtUtc": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "packageName": "codex-ui-linux-port"
}
JSON

(cd "$DIST" && find . -maxdepth 1 -type f \( -name '*.dmg' -o -name '*.zip' -o -name '*.deb' -o -name '*.rpm' -o -name '*.pkg.tar.zst' -o -name 'manifest.json' \) -printf '%P\n' | sort | xargs -r sha256sum > checksums.txt)
echo "build-from-dmg: artifacts written to $DIST"
