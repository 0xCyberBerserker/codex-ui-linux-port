#!/usr/bin/env bash
set -euo pipefail

APP_SRC="${1:?app-src path required}"
BS="$APP_SRC/node_modules/better-sqlite3"

[[ -d "$BS" ]] || { echo "patch-native-modules: better-sqlite3 not found" >&2; exit 1; }

node - "$BS" <<'NODE'
const fs = require("fs");
const path = require("path");
const root = process.argv[2];

function patch(file, transform) {
  const p = path.join(root, file);
  if (!fs.existsSync(p)) return;
  const before = fs.readFileSync(p, "utf8");
  const after = transform(before);
  if (after !== before) fs.writeFileSync(p, after, "utf8");
}

patch("src/util/macros.cpp", text => {
  if (!text.includes("BETTER_SQLITE3_EXTERNAL_TAG")) {
    text = text.replace(
      /(#include[^\n]*\n)/,
      `$1
#ifndef BETTER_SQLITE3_EXTERNAL_TAG
#if V8_MAJOR_VERSION >= 14
#define BETTER_SQLITE3_EXTERNAL_TAG v8::kExternalPointerTypeTagDefault
#define BETTER_SQLITE3_EXTERNAL_VALUE(external) (external)->Value(BETTER_SQLITE3_EXTERNAL_TAG)
#define BETTER_SQLITE3_EXTERNAL_NEW(isolate, value) v8::External::New((isolate), (value), BETTER_SQLITE3_EXTERNAL_TAG)
#else
#define BETTER_SQLITE3_EXTERNAL_VALUE(external) (external)->Value()
#define BETTER_SQLITE3_EXTERNAL_NEW(isolate, value) v8::External::New((isolate), (value))
#endif
#endif
`
    );
  }
  text = text.replace(
    /([A-Za-z0-9_:().<>]+\.As<v8::External>\(\))->Value\(\)/g,
    "BETTER_SQLITE3_EXTERNAL_VALUE($1)"
  );
  return text;
});

patch("src/better_sqlite3.cpp", text =>
  text.replace(/v8::External::New\(([^,]+),\s*([^)]+)\)/g, "BETTER_SQLITE3_EXTERNAL_NEW($1, $2)")
);

patch("src/util/helpers.cpp", text =>
  text.replace(/SetNativeDataProperty\(([^;]*?),\s*0\s*\)/gs, "SetNativeDataProperty($1, nullptr)")
);
NODE

echo "patch-native-modules: applied better-sqlite3 Electron 42 compatibility patch"

