#!/usr/bin/env bash
set -euo pipefail

REPO="${CODEXUI_REPO:-0xCyberBerserker/codex-ui-linux-port}"
PROGRAM="codexui-update"
MODE="install"
FORCE=0
SMOKE=0
REQUESTED_VERSION=""

usage() {
  cat <<'EOF'
Usage:
  codexui-update [--check] [--force] [--version VERSION] [--smoke]

Options:
  --check            Print current/latest versions without installing.
  --force            Reinstall the selected release.
  --version VERSION  Install a specific release tag/version.
  --smoke            Run a temporary-profile startup smoke test after install.
  --help             Show this help.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --check) MODE="check" ;;
    --force) FORCE=1 ;;
    --version)
      shift
      REQUESTED_VERSION="${1:-}"
      [[ -n "$REQUESTED_VERSION" ]] || { echo "$PROGRAM: --version requires a value" >&2; exit 2; }
      ;;
    --smoke) SMOKE=1 ;;
    --help|-h) usage; exit 0 ;;
    --aur)
      echo "$PROGRAM: AUR mode is reserved until the AUR package is published" >&2
      exit 2
      ;;
    *) echo "$PROGRAM: unknown option: $1" >&2; usage >&2; exit 2 ;;
  esac
  shift
done

[[ "$REPO" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]] || {
  echo "$PROGRAM: invalid GitHub repository: $REPO" >&2
  exit 2
}
if [[ -n "$REQUESTED_VERSION" && ! "$REQUESTED_VERSION" =~ ^v?[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "$PROGRAM: invalid version: $REQUESTED_VERSION" >&2
  exit 2
fi

need() {
  command -v "$1" >/dev/null 2>&1 || { echo "$PROGRAM: missing required command: $1" >&2; exit 2; }
}

need uname
need mktemp
need sed
need grep
need sha256sum
need jq
need curl

arch="$(uname -m)"
if [[ "$arch" != "x86_64" ]]; then
  echo "$PROGRAM: unsupported architecture: $arch" >&2
  exit 2
fi

if [[ -r /etc/os-release ]]; then
  # shellcheck disable=SC1091
  . /etc/os-release
else
  echo "$PROGRAM: /etc/os-release not found" >&2
  exit 2
fi

id="${ID:-}"
id_like="${ID_LIKE:-}"
pkg_kind=""
install_cmd=()
deps=()

case " $id $id_like " in
  *" arch "*|*" cachyos "*)
    pkg_kind="pkg.tar.zst"
    deps=(electron42 nodejs curl jq desktop-file-utils)
    install_cmd=(pacman -U --needed)
    ;;
  *" debian "*|*" ubuntu "*)
    pkg_kind="deb"
    deps=(electron42 nodejs curl jq desktop-file-utils)
    install_cmd=(apt-get install -y)
    ;;
  *" fedora "*|*" rhel "*|*" centos "*)
    pkg_kind="rpm"
    deps=(electron42 nodejs curl jq desktop-file-utils)
    install_cmd=(dnf install -y)
    ;;
  *)
    echo "$PROGRAM: unsupported distro: ID=$id ID_LIKE=$id_like" >&2
    exit 2
    ;;
esac

current_version() {
  if command -v codex-ui-linux >/dev/null 2>&1; then
    codex-ui-linux --version 2>/dev/null | sed -n 's/.*\([0-9][0-9]\.[0-9][0-9][0-9]\.[0-9][0-9]*\).*/\1/p' | head -n 1
  fi
}

api_json="$(mktemp)"
trap 'rm -f "$api_json"; [[ -n "${tmpdir:-}" ]] && rm -rf "$tmpdir"' EXIT

github_headers=(-H "X-GitHub-Api-Version: 2022-11-28")
github_token="${GITHUB_TOKEN:-${GH_TOKEN:-}}"
if [[ -n "$github_token" ]]; then
  github_headers+=(-H "Authorization: Bearer $github_token")
fi

github_api() {
  local endpoint="$1"
  curl -fsSL "${github_headers[@]}" -H "Accept: application/vnd.github+json" \
    "https://api.github.com/$endpoint"
}

download_asset() {
  local asset_id="$1"
  local destination="$2"
  curl -fL "${github_headers[@]}" -H "Accept: application/octet-stream" \
    "https://api.github.com/repos/$REPO/releases/assets/$asset_id" \
    -o "$destination"
}

if [[ -n "$REQUESTED_VERSION" ]]; then
  tag="$REQUESTED_VERSION"
  [[ "$tag" == v* ]] || tag="v$tag"
  github_api "repos/$REPO/releases/tags/$tag" > "$api_json"
else
  github_api "repos/$REPO/releases/latest" > "$api_json"
  tag="$(jq -r '.tag_name' "$api_json")"
fi

[[ "$(jq -r '.tag_name // empty' "$api_json")" == "$tag" ]] || {
  echo "$PROGRAM: release not found: $tag" >&2
  exit 1
}

latest_version="${tag#v}"
installed_version="$(current_version || true)"

if [[ "$MODE" == "check" ]]; then
  echo "installed=${installed_version:-none}"
  echo "latest=$latest_version"
  echo "package=$pkg_kind"
  exit 0
fi

if [[ "$FORCE" -ne 1 && -n "$installed_version" && "$installed_version" == "$latest_version" ]]; then
  echo "$PROGRAM: already up to date ($installed_version)"
  [[ "$SMOKE" -eq 1 ]] || exit 0
fi

tmpdir="$(mktemp -d)"
case "$pkg_kind" in
  pkg.tar.zst) asset_suffix=".pkg.tar.zst" ;;
  deb) asset_suffix="_amd64.deb" ;;
  rpm) asset_suffix=".x86_64.rpm" ;;
esac

mapfile -t package_assets < <(jq -r --arg version "$latest_version" --arg suffix "$asset_suffix" \
  '.assets[] | select(.name | contains($version) and endswith($suffix)) | [.id, .name] | @tsv' "$api_json")
[[ "${#package_assets[@]}" -eq 1 ]] || {
  echo "$PROGRAM: expected one package asset for $pkg_kind, found ${#package_assets[@]}" >&2
  exit 1
}

IFS=$'\t' read -r package_asset_id package_asset_name <<< "${package_assets[0]}"
mapfile -t checksums_assets < <(jq -r \
  '.assets[] | select(.name == "checksums.txt") | [.id, .name] | @tsv' "$api_json")
[[ "${#checksums_assets[@]}" -eq 1 ]] || { echo "$PROGRAM: expected one checksums.txt release asset" >&2; exit 1; }
IFS=$'\t' read -r checksums_asset_id checksums_asset_name <<< "${checksums_assets[0]}"

echo "$PROGRAM: downloading $package_asset_name from $REPO $tag"
download_asset "$package_asset_id" "$tmpdir/$package_asset_name"
download_asset "$checksums_asset_id" "$tmpdir/$checksums_asset_name"

package="$(find "$tmpdir" -maxdepth 1 -type f -name "*.${pkg_kind}" | head -n 1)"
[[ -n "$package" ]] || { echo "$PROGRAM: package asset not found for $pkg_kind" >&2; exit 1; }

package_name="$(basename "$package")"
package_covered=0
while read -r expected_sha asset_name extra; do
  [[ "$expected_sha" =~ ^[0-9a-f]{64}$ ]] || { echo "$PROGRAM: invalid checksum entry" >&2; exit 1; }
  [[ -n "$asset_name" && -z "${extra:-}" && "$(basename "$asset_name")" == "$asset_name" ]] || {
    echo "$PROGRAM: unsafe checksum asset name" >&2
    exit 1
  }
  [[ "$asset_name" == "$package_name" ]] && package_covered=1
done < "$tmpdir/checksums.txt"
[[ "$package_covered" -eq 1 ]] || { echo "$PROGRAM: package is not covered by checksums.txt" >&2; exit 1; }

(cd "$tmpdir" && sha256sum -c checksums.txt --ignore-missing)

missing=()
for dep in "${deps[@]}"; do
  case "$pkg_kind" in
    pkg.tar.zst) pacman -Qi "$dep" >/dev/null 2>&1 || missing+=("$dep") ;;
    deb) dpkg -s "$dep" >/dev/null 2>&1 || missing+=("$dep") ;;
    rpm) rpm -q "$dep" >/dev/null 2>&1 || missing+=("$dep") ;;
  esac
done

elevate=()
if [[ "$(id -u)" -eq 0 ]]; then
  elevate=()
elif command -v sudo >/dev/null 2>&1; then
  elevate=(sudo)
elif command -v pkexec >/dev/null 2>&1; then
  elevate=(pkexec)
else
  echo "$PROGRAM: root privileges required, but sudo/pkexec not found" >&2
  exit 2
fi

if [[ "${#missing[@]}" -gt 0 ]]; then
  echo "$PROGRAM: installing missing dependencies: ${missing[*]}"
  case "$pkg_kind" in
    pkg.tar.zst) "${elevate[@]}" pacman -S --needed "${missing[@]}" ;;
    deb) "${elevate[@]}" apt-get install -y "${missing[@]}" ;;
    rpm) "${elevate[@]}" dnf install -y "${missing[@]}" ;;
  esac
fi

echo "$PROGRAM: installing $package"
"${elevate[@]}" "${install_cmd[@]}" "$package"

command -v codex-ui-linux >/dev/null 2>&1 || { echo "$PROGRAM: codex-ui-linux not found after install" >&2; exit 1; }
command -v codexui-update >/dev/null 2>&1 || { echo "$PROGRAM: codexui-update not found after install" >&2; exit 1; }

if [[ "$SMOKE" -eq 1 ]]; then
  profile="$(mktemp -d)"
  log="$tmpdir/smoke.log"
  CODEX_ELECTRON_USER_DATA_PATH="$profile" timeout 20s codex-ui-linux >"$log" 2>&1 || true
  if ! grep -E 'Codex CLI initialized|window ready-to-show' "$log" >/dev/null 2>&1; then
    echo "$PROGRAM: smoke test did not find a successful startup marker" >&2
    tail -n 80 "$log" >&2
    exit 1
  fi
fi

echo "$PROGRAM: installed $latest_version"
